# --- Database ---
# Production / Docker (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://scheduler_user:scheduler_pass@localhost:5432/scheduler_db
# Local dev without Postgres installed, swap to SQLite instead:
# DATABASE_URL=sqlite+aiosqlite:///./scheduler.db

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Scheduler loop ---
SCHEDULER_TICK_SECONDS=2.0

# --- Worker ---
WORKER_ID=worker-local
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_HEARTBEAT_INTERVAL_SECONDS=5.0